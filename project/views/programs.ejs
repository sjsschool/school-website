    <main>
        <section class="programs-hero">
            <div class="programs-hero-content">
                <h1>Our Programs</h1>
                <p>Nurturing minds, Building futures - From First Grade to Senior High</p>
            </div>
        </section>

        <section class="programs-content">
            <div class="container">
                <div class="program-grid">
                    <div class="program-card">
                        <h3>Elementary (Grades 1-6)</h3>
                        <p>Building a strong foundation in core subjects.</p>
                        <ul>
                            <li>Comprehensive curriculum aligned with national standards</li>
                            <li>Emphasis on critical thinking and problem-solving</li>
                            <li>Engaging learning experiences and projects</li>
                        </ul>
                    </div>
                    <div class="program-card">
                        <h3>Junior High (Grades 7-10)</h3>
                        <p>Preparing students for higher education and beyond.</p>
                        <ul>
                            <li>Challenging academic program</li>
                            <li>Development of leadership and teamwork skills</li>
                            <li>Exploration of different career paths</li>
                        </ul>
                    </div>
                    <div class="program-card">
                        <h3>Senior High (Grades 11-12)</h3>
                        <p>Specialized tracks to prepare for university and careers.</p>
                        <ul>
                            <li>Advanced coursework in various disciplines</li>
                            <li>Guidance and support for college applications</li>
                            <li>Opportunities for internships and research</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <section class="cta">
            <h2>Ready to Join Our Community?</h2>
            <p>Take the first step towards excellent education</p>
            <button class="cta-btn">Apply Now</button>
        </section>

