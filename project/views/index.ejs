<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Saint Joseph School, Addis Ababa</title>
    <link rel="stylesheet" href="css/style.css">
</head>

<body>
    <header>
        <nav>
            <div class="logo">
                <img src="/assests/sjs-logo.png" alt="Saint Joseph School Logo">
            </div>
            <button class="mobile-menu-btn" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/aboutUs">About</a>
                <a href="/programs">Programs</a>
                <!--<a href="admissions.html">Admissions</a>-->
                <a href="/contactUs">Contact</a>
            </div>
        </nav>
    </header>

    <main>
        <section class="hero">
            <div class="hero-content">
                <h1>Welcome to Saint Joseph School</h1>
                <p>Nurturing minds, Building futures - G1 to Grade 12 Education</p>
                <button class="cta-btn">Learn More</button>
            </div>
        </section>

        <section class="features">
            <div class="feature-card">
                <h3>Academic Excellence</h3>
                <p>Comprehensive curriculum focused on student success</p>
            </div>
            <div class="feature-card">
                <h3>Holistic Development</h3>
                <p>Balanced approach to academic and personal growth</p>
            </div>
            <div class="feature-card">
                <h3>Modern Facilities</h3>
                <p>State-of-the-art learning environments</p>
            </div>
        </section>

        <section class="programs">
            <h2>Our Programs</h2>
            <div class="program-grid">

                <div class="program-card">
                    <h3>Elementary</h3>
                    <p>Grades 1-6 fundamental education</p>
                </div>
                <div class="program-card">
                    <h3>Junior High</h3>
                    <p>Grades 7-10 advanced learning</p>
                </div>
                <div class="program-card">
                    <h3>Senior High</h3>
                    <p>Grades 11-12 specialized tracks</p>
                </div>
            </div>
        </section>

        <section class="cta">
            <h2>Ready to Join Our Community?</h2>
            <p>Take the first step towards excellent education</p>
            <button class="cta-btn">Apply Now</button>
        </section>
    </main>

    <footer>
        <div class="footer-content">
            <div class="footer-section">
                <h4>Contact Us</h4>
                <p>Email: admissions@saintjoseph.edu</p>
                <p>Phone: (555) 123-4567</p>
            </div>
            <div class="footer-section">
                <h4>Quick Links</h4>
                <a href="aboutUs.html">About</a>
                <a href="programs.html">Programs</a>
                <a href="admissions.html">Admissions</a>
                <a href="contactUs.html">Contact</a>
            </div>
            <div class="footer-section">
                <h4>Follow Us</h4>
                <div class="social-links">
                    <a href="#">Facebook</a>
                    <a href="#">Twitter</a>
                    <a href="#">Instagram</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2025 Saint Joseph School. All rights reserved.</p>
        </div>
    </footer>

    <script src="/assests/main.js"></script>
    <script src="/assests/counter.js"></script>
