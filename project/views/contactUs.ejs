<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Saint Joseph School, Addis Ababa</title>
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/contactUs.css">
</head>

<body>
    <header>
        <nav>
            <div class="logo">
                <img src="/assests/sjs-logo.png" alt="Saint Joseph School Logo">
            </div>
            <button class="mobile-menu-btn" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/aboutUs">About</a>
                <a href="/programs">Programs</a>
                <!--<a href="admissions.html">Admissions</a>-->
                <a href="/contactUs">Contact</a>
            </div>
        </nav>
    </header>

    <main class="contact-container">
        <div class="contact-column">
            <h2>Contact Us</h2>
            <p>School Information</p>
            <p><b>Address:</b> Addis Ababa, Ethiopia, Mesquel Square</p>
            <p><b>Phone:</b> +251 11 551 0868</p>
            <p><b>Email:</b> info@example.com</p>
            <p><b>Telegram:</b> <a href="https://t.me/sjschoolgr9">https://t.me/sjschoolgr9</a></p>
            <div class="map">
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1229.6481763783306!2d38.76073676442655!3d9.00941414068018!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x164b85b8fbee5c05%3A0xdcd4da62cb92b558!2zU2FpbnQgSm9zZXBoIFNjaG9vbCB8IE1lc2tlbCBTcXVhcmUgfCDhiYXhi7HhiLUg4Yuu4Yi04Y2NIOGJtS_hiaThibUgfCDhiJjhiLXhiYDhiI0g4Yqg4Yuw4Ymj4Ymj4Yut!5e1!3m2!1sen!2set!4v1720463912882!5m2!1sen!2set"
                    width="550" height="450" id="googlemap" allowfullscreen="" loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>

        <div class="contact-column">
            <h2>Contact Form</h2>
            <form class="contact-form" action="/contactUs" method="post">
                <div class="form-group">
                    <label for="name">Name</label>
                    <input type="text" id="name" name="name" required>
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required>
                </div>
                <div class="form-group">
                    <label for="subject">Subject</label>
                    <input type="text" id="subject" name="subject" required>
                </div>
                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" name="message" rows="3" required></textarea>
                </div>
                <button type="submit">Submit</button>
            </form>
        </div>
    </main>

    <footer>
        <div class="footer-content">
            <div class="footer-section">
                <h4>Contact Us</h4>
                <p>Email: admissions@saintjoseph.edu</p>
                <p>Phone: (555) 123-4567</p>
            </div>
            <div class="footer-section">
                <h4>Quick Links</h4>
                <a href="aboutUs.html">About</a>
                <a href="programs.html">Programs</a>
                <a href="admissions.html">Admissions</a>
                <a href="contactUs.html">Contact</a>
            </div>
            <div class="footer-section">
                <h4>Follow Us</h4>
                <div class="social-links">
                    <a href="#">Facebook</a>
                    <a href="#">Twitter</a>
                    <a href="#">Instagram</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2025 Saint Joseph School. All rights reserved.</p>
        </div>
    </footer>

    <script src="/assests/main.js"></script>
    <script src="/assests/counter.js"></script>
</body>

</html>